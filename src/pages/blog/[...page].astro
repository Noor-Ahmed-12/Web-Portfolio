---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HorizontalCard from "../../components/HorizontalCard.astro";
import { getCollection } from "astro:content";
import createSlug from "../../lib/createSlug"

export async function getStaticPaths({ paginate }) {
  const posts = await getCollection("blog");
  posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  return paginate(posts, { pageSize: 20 });
}

const { page } = Astro.props;

// Grouping Logic - Match these strings to your Markdown tags exactly
const impactPosts = page.data.filter(post => 
  post.data.tags?.some(tag => ["Social Impact", "Mentorship", "Education Equity", "Civic Tech"].includes(tag))
);

const technicalDeepDives = page.data.filter(post => 
  post.data.tags?.some(tag => ["GreenOps", "AI Agents", "FinTech", "Cloud Native", "Global Innovation"].includes(tag))
);

const developmentProjects = page.data.filter(post => 
  post.data.tags?.some(tag => ["PHP", "Java", "React.js", "Web Engineering", "DSA"].includes(tag))
);
---

<BaseLayout title="Technical Blog & Leadership Portfolio" sideBarActiveItemID="blog">
  <style>
    /* Custom badge styling for scholarship narrative */
    :global(.badge-social) { @apply bg-green-100 text-green-700 border-green-200; }
    :global(.badge-innovation) { @apply bg-blue-100 text-blue-700 border-blue-200; }
    :global(.badge-academic) { @apply bg-slate-100 text-slate-700 border-slate-200; }
  </style>

  <div class="mb-10">
    <div class="text-3xl w-full font-bold text-primary">Technical Blog & Insights</div>
    <p class="py-2 text-lg opacity-80 italic">
      Bridging the gap between high-performance Cloud Architecture and sustainable Social Impact.
    </p>
  </div>

  {page.data.length === 0 ? (
    <div class="bg-base-200 border-l-4 border-secondary w-full p-4 min-w-full">
      <p class="font-bold">No posts found.</p>
    </div>
  ) : (
    <div class="space-y-16">
      
      {impactPosts.length > 0 && (
        <section>
          <div class="flex items-center justify-between mb-6 border-b border-base-300 pb-2">
            <div class="flex items-center gap-2">
              <div class="p-2 bg-success/10 rounded-lg">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-success"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              </div>
              <h2 class="text-2xl font-bold uppercase tracking-tight">Social Impact & Leadership</h2>
            </div>
            <span class="text-xs font-medium opacity-50 uppercase tracking-widest font-mono">Section 01</span>
          </div>
          
          <div class="grid gap-6">
            {impactPosts.map((post) => (
              <HorizontalCard
                title={post.data.title}
                img={post.data.heroImage}
                desc={post.data.description}
                url={"/blog/" + createSlug(post.data.title, post.slug)}
                badge={post.data.badge}
                tags={post.data.tags}
              />
            ))}
          </div>
        </section>
      )}

      {technicalDeepDives.length > 0 && (
        <section>
          <div class="flex items-center justify-between mb-6 border-b border-base-300 pb-2">
            <div class="flex items-center gap-2">
              <div class="p-2 bg-primary/10 rounded-lg">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-primary"><path d="M12 2v8"/><path d="m4.93 10.93 1.41 1.41"/><path d="M2 18h2"/><path d="M20 18h2"/><path d="m19.07 10.93-1.41 1.41"/><path d="M22 22H2"/><path d="m8 22 4-10 4 10"/><path d="M12 18H2"/></svg>
              </div>
              <h2 class="text-2xl font-bold uppercase tracking-tight">Cloud & AI Architecture</h2>
            </div>
             <span class="text-xs font-medium opacity-50 uppercase tracking-widest font-mono">Section 02</span>
          </div>
          
          <div class="grid gap-6">
            {technicalDeepDives.map((post) => (
              <HorizontalCard
                title={post.data.title}
                img={post.data.heroImage}
                desc={post.data.description}
                url={"/blog/" + createSlug(post.data.title, post.slug)}
                badge={post.data.badge}
                tags={post.data.tags}
              />
            ))}
          </div>
        </section>
      )}

      {developmentProjects.length > 0 && (
        <section>
          <div class="flex items-center justify-between mb-6 border-b border-base-300 pb-2">
            <div class="flex items-center gap-2">
              <div class="p-2 bg-base-300 rounded-lg">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="opacity-70"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
              </div>
              <h2 class="text-2xl font-bold uppercase tracking-tight">Software Engineering Foundations</h2>
            </div>
             <span class="text-xs font-medium opacity-50 uppercase tracking-widest font-mono">Section 03</span>
          </div>
          <div class="grid gap-6 opacity-85">
            {developmentProjects.map((post) => (
              <HorizontalCard
                title={post.data.title}
                img={post.data.heroImage}
                desc={post.data.description}
                url={"/blog/" + createSlug(post.data.title, post.slug)}
                badge={post.data.badge}
                tags={post.data.tags}
              />
            ))}
          </div>
        </section>
      )}
    </div>
  )}

  {(page.url.prev || page.url.next) && (
    <div class="flex justify-between mt-16 pt-8 border-t border-base-300">
      {page.url.prev ? (
        <a href={page.url.prev} class="btn btn-outline btn-sm">
          <svg class="h-4 w-4 fill-current mr-2" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M15.41,16.58L10.83,12L15.41,7.41L14,6L8,12L14,18L15.41,16.58Z" /></svg> 
          Newer
        </a>
      ) : <div />}
      {page.url.next ? (
        <a href={page.url.next} class="btn btn-outline btn-sm">
          Older 
          <svg class="h-4 w-4 fill-current ml-2" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z" /></svg>
        </a>
      ) : <div />}
    </div>
  )}
</BaseLayout>